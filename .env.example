# DEVONN.ai Scheduler Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to git - it contains secrets!

# =============================================================================
# CORE SCHEDULER SETTINGS
# =============================================================================

# Event loop tick interval (milliseconds)
DEVONN_TICK_INTERVAL=2000

# Maximum concurrent task execution
DEVONN_MAX_CONCURRENT=5

# Default task timeout (milliseconds)
DEVONN_DEFAULT_TIMEOUT=300000

# Data persistence path
DEVONN_DATA_PATH=./data

# Dashboard API port
DEVONN_API_PORT=7373

# Dashboard API URL (for CLI)
DEVONN_API_URL=http://localhost:7373

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log to file (in addition to stdout)
LOG_FILE=./logs/scheduler.log

# Max log file size (bytes) before rotation
LOG_MAX_SIZE=10485760

# Number of rotated log files to keep
LOG_MAX_FILES=5

# =============================================================================
# ECOSYSTEM CONNECTION (Optional)
# =============================================================================

# Set to 'true' to connect to Devonn.ai ecosystem
ENABLE_ECOSYSTEM=false

# Central orchestrator endpoint
ORCHESTRATOR_URL=https://central-orchestrator.onrender.com

# OpenClaw gateway endpoint
GATEWAY_URL=https://openclaw-gateway-2t9e.onrender.com

# Your GitHub organization/username
ORGANIZATION=wesship

# Poll interval for ecosystem tasks (milliseconds)
POLL_INTERVAL=30000

# =============================================================================
# GITHUB INTEGRATION (Required for GitHub monitor tasks)
# =============================================================================

# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:org
GITHUB_TOKEN=

# =============================================================================
# AI PROVIDERS (Required for AI-powered repairs)
# =============================================================================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: Custom OpenAI API base URL
# OPENAI_API_BASE=https://api.openai.com/v1

# Optional: Default model for repairs
# OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# SECURITY
# =============================================================================

# Node environment: development, production
NODE_ENV=production

# Disable colored output in logs (for systemd journal)
# NO_COLOR=1

# =============================================================================
# MONITORING (Optional)
# =============================================================================

# Health check endpoint for external monitoring
# HEALTH_CHECK_URL=https://your-monitoring-service.com/ping

# Alert webhook for critical failures
# ALERT_WEBHOOK_URL=

# =============================================================================
# DEVELOPMENT (Don't use in production)
# =============================================================================

# Enable debug mode (verbose logging)
# DEBUG=devonn:*

# Disable task persistence (in-memory only)
# DEVONN_NO_PERSIST=true
